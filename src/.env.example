# Copy this file to .env and fill in the keys you need.
# Only the keys relevant to your chosen stack are required.

# ── Claim extraction ──────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=       # needed for AnthropicClaimExtractor
OPENAI_API_KEY=          # needed for OpenAIClaimExtractor
HF_KEY=                  # needed only for gated HuggingFace models (e.g. Gemma)

# ── Search ────────────────────────────────────────────────────────────────────
# DuckDuckGoSourcesFinder needs no key.
SERPER_KEY=              # needed for SerperAPISourcesFinder  (serper.dev)
TAVILY_KEY=              # needed for TavilySourcesFinder     (tavily.com)
SERPAPI_KEY=             # needed for SerpApiSourcesFinder    (serpapi.com)
